import { useState } from 'react'


const Button = (props) => (
  <button onClick={props.onClick}>
    {props.text}
  </button>
)

const AllReviews = (props) => {
  if (props.allReviews === 0){
    return (
    <div>you need to press buttons to get statistics</div>
    )
  }
  return (
    <div>positive {(good /allReviews) * 100}% </div>
  )

}

const App = () => {
  // save clicks of each button to its own state
  const [good, setGood] = useState(0)
  const [neutral, setNeutral] = useState(0)
  const [bad, setBad] = useState(0)
  const allReviews = good + neutral + bad

  const increaseByOneGood = () => {
    setGood(good + 1)
  }
  const increaseByOneNeutral = () => {
    setNeutral(neutral + 1)
  }
  const increaseByOneBad = () => {
    setBad(bad + 1)
  }
  if (allReviews === 0) {
    return (
    <div>
      <h1>give feedback</h1>
      
      <Button onClick={increaseByOneGood} text="good" />
      <Button onClick={increaseByOneNeutral} text="neutral" />
      <Button onClick={increaseByOneBad} text="bad" />
      <h1>statistics</h1>
      <div>good {good}</div>
      <div>neutral {neutral}</div>
      <div>bad {bad}</div>
      <div>all {allReviews}</div>
      <div>average - give values first!</div>
      <div>positive - give values first!</div>
    </div>
    )
  }
  return (
    <div>
      <h1>give feedback</h1>
      
      <Button onClick={increaseByOneGood} text="good" />
      <Button onClick={increaseByOneNeutral} text="neutral" />
      <Button onClick={increaseByOneBad} text="bad" />
      <h1>statistics</h1>
      <div>good {good}</div>
      <div>neutral {neutral}</div>
      <div>bad {bad}</div>
      <div>all {allReviews}</div>
      <div>average {(good - bad) /allReviews}</div>
      <div>positive {(good /allReviews) * 100}%</div>
    </div>
  )
}

export default App
